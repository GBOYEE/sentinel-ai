# Sentinel AI Environment Configuration

# GitHub App credentials
GH_APP_ID=your_app_id
GH_WEBHOOK_SECRET=your_webhook_secret
# Store private key in secrets/gh_private_key.pem (DO NOT commit)

# LLM settings (choose OpenRouter or Ollama)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openai/gpt-4o-mini
# OR for local:
OLLAMA_BASE_URL=http://localhost:11434

# Database & cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinel
REDIS_URL=redis://localhost:6379/0

# Chroma memory
CHROMA_PERSIST_DIR=./chroma_data

# Feature flags
ENABLE_STATIC_ANALYSIS=true
ENABLE_LLM_REVIEW=true
SCAN_TIMEOUT=300
